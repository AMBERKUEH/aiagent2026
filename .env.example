# Copy this file to .env for local development only.
# Do not put real values in Git.

# Server-side secrets. In Cloud Run, store these in Secret Manager.
GROQ_API_KEY=replace-with-groq-api-key
GEMINI_API_KEY=replace-with-gemini-api-key
OPENWEATHERMAP_API_KEY=replace-with-openweathermap-api-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_S3_SECRET_ACCESS_KEY=replace-with-supabase-s3-secret-access-key

# Public browser runtime config. These are written into /env.js at container start.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
VITE_FIREBASE_DATABASE_URL=replace-with-firebase-database-url
VITE_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=replace-with-firebase-app-id
VITE_SUPABASE_URL=replace-with-supabase-url
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
VITE_MARKET_API_URL=
VITE_USE_MOCK_MARKET=false

# Optional local scripts only.
SUPABASE_S3_ENDPOINT=replace-with-supabase-s3-endpoint
SUPABASE_S3_REGION=replace-with-supabase-s3-region
SUPABASE_S3_ACCESS_KEY_ID=replace-with-supabase-s3-access-key-id
SUPABASE_S3_BUCKET=replace-with-supabase-s3-bucket
SUPABASE_S3_PUBLIC_BASE_URL=
