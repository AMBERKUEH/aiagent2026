# Frontend-only prototype key for the current Vite chat page.
# Move Groq requests to a backend before production so this key is not exposed in the browser.
VITE_GROQ_API_KEY=your_groq_api_key_here

# Firebase powers live sensor readings from Realtime Database.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Supabase stores agriculture document chunks for chatbot retrieval.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side key for upload scripts only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

SUPABASE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY_ID=your_supabase_s3_access_key_id_here
SUPABASE_S3_SECRET_ACCESS_KEY=your_supabase_s3_secret_access_key_here
SUPABASE_S3_BUCKET=agriculture-docs
# Optional: use this if your bucket is public or served through a CDN/public URL.
SUPABASE_S3_PUBLIC_BASE_URL=https://your-project-ref.supabase.co/storage/v1/object/public/agriculture-docs
